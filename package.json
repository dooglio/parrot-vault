{
  "name": "parrot-vault",
  "productName": "ParrotVault",
  "version": "1.0.1",
  "description": "ParrotVault — open-source desktop app for managing multiple cryptocurrency wallets",
  "main": "dist-electron/main/index.js",
  "homepage": "https://github.com/dooglio/parrot-vault",
  "author": "dooglio",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "electron:build": "npm run build && electron-builder --mac --universal",
    "electron:pack": "npm run build && electron-builder --dir",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.3",
    "better-sqlite3": "^11.9.1",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.8.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.2.12",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dooglio.parrot-vault",
    "productName": "ParrotVault",
    "copyright": "Copyright © 2026 R. Douglas Barbieri",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "icon": "build/icons/app.icns",
      "category": "public.app-category.finance",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Camera access is needed to scan QR codes.",
        "NSScreenCaptureDescription": "Screen recording is needed to read QR codes displayed on screen."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "ParrotVault",
      "icon": "build/icons/app.icns"
    },
    "win": {
      "icon": "build/icons/app.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icons/",
      "category": "Finance",
      "target": "deb",
      "desktop": {
        "Name": "ParrotVault",
        "Comment": "Manage multiple cryptocurrency wallets",
        "Categories": "Finance;Office;"
      }
    },
    "npmRebuild": true
  }
}
