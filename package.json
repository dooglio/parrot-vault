{
  "name": "parrot-vault",
  "version": "1.0.0",
  "description": "PolyVault — open-source desktop app for managing multiple cryptocurrency wallets",
  "main": "dist-electron/main/index.js",
  "homepage": "https://github.com/dooglio/parrot-vault",
  "author": "dooglio",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --mac",
    "electron:pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.3",
    "better-sqlite3": "^11.9.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dooglio.parrot-vault",
    "productName": "PolyVault",
    "copyright": "Copyright © 2024 dooglio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "icon": "build/icons/app.icns",
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "title": "PolyVault",
      "icon": "build/icons/app.icns"
    },
    "win": {
      "icon": "build/icons/app.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icons/",
      "category": "Finance",
      "target": "deb",
      "desktop": {
        "Name": "PolyVault",
        "Comment": "Manage multiple cryptocurrency wallets",
        "Categories": "Finance;Office;"
      }
    },
    "nativeRebuilder": "sequential",
    "npmRebuild": true
  }
}
